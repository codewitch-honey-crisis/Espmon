[
    {
        "name": "Default",
        "definition": {
            "top": {
                "label": "CPU",
                "color": "#E0E635",
                "value1": {
                    "value": "alt(round(avg('^/coretemp/cpu/[0-9]+/core/[0-9]+/load$')), round(avg('^/win32/cpu/[0-9]+/thread/[0-9]+/load$')))",
                    "max": 100,
                    "min": 0,
                    "color": "green"
                },
                "value2": {
                    "value": "alt(round(max('^/coretemp/cpu/[0-9]+/core/[0-9]+/temperature$')), (round1(avg('^/win32/cpu/[0-9]+/thread/[0-9]+/clock$') / 1000))GHz)",
                    "max": "alt(min('^/coretemp/cpu/[0-9]+/tjmax$'), 5GHz)",
                    "min": 0,
                    "color": "orange",
                    "has_gradient": true
                }
            },
            "bottom": {
                "label": "GPU",
                "color": "#FF4945",
                "value1": {
                    "value": "round(avg('^/.+/gpu/[0-9]+/load$'))",
                    "max": 100,
                    "min": 0
                },
                "value2": {
                    "value": "round(max('^/.+/gpu/[0-9]+/temperature$'))",
                    "max": 90,
                    "min": 0,
                    "color": "purple",
                    "has_gradient": true
                }
            }
        }
    },
    {
        "name": "Gaming",
        "definition": {
            "interval": 100,
            "top": {
                "label": "1%</Avg",
                "color": "yellow",
                "value1": {
                    "value": "round(/dxgi/framerate)",
                    "max": "/dxgi/refreshrate",
                    "min": 0,
                    "color": "#91CFD9"
                },
                "value2": {
                    "value": "round(/dxgi/1pctlows)",
                    "max": "/dxgi/refreshrate",
                    "min": 0,
                    "color": "#CCCAFF"
                }
            },
            "bottom": {
                "label": "Min/Max",
                "color": "light-sea-green",
                "value1": {
                    "value": "round1(/dxgi/maxrender)",
                    "max": 1000,
                    "min": 0,
                    "color": "#780507"
                },
                "value2": {
                    "value": "round1(/dxgi/minrender)",
                    "max": 1000,
                    "min": 0,
                    "color": "#DB8FD4"
                }
            }
        }
    },
    {
        "name": "History",
        "definition": {
            "top": {
                "label": "CPU 5 min",
                "color": "#1228E6",
                "value1": {
                    "value": "max(past(5m, alt(round(avg('^/coretemp/cpu/[0-9]+/core/[0-9]+/load$')), round(avg('^/win32/cpu/[0-9]+/thread/[0-9]+/load$')))))",
                    "max": 100,
                    "min": 0,
                    "color": "#258058"
                },
                "value2": {
                    "value": "max(past(5m, alt(round(max('^/coretemp/cpu/[0-9]+/core/[0-9]+/temperature$')), (round1(avg('^/win32/cpu/[0-9]+/thread/[0-9]+/clock$') / 1000))GHz)))",
                    "max": "alt(min('^/coretemp/cpu/[0-9]+/tjmax$'), 5GHz)",
                    "min": 0,
                    "color": "#FF7F21",
                    "has_gradient": true
                }
            },
            "bottom": {
                "label": "GPU 5 min",
                "color": "#FF654C",
                "value1": {
                    "value": "max(past(5m, round(avg('^/.+/gpu/[0-9]+/load$'))))",
                    "max": 100,
                    "min": 0,
                    "color": "#FFFE9B"
                },
                "value2": {
                    "value": "max(past(5m, round(avg('^/.+/gpu/[0-9]+/temperature$'))))",
                    "max": 90,
                    "min": 0,
                    "color": "#7F4980",
                    "has_gradient": true
                }
            }
        }
    },
    {
        "name": "RAM and Disk",
        "definition": {
            "top": {
                "label": "RAM",
                "color": "light-blue",
                "value1": {
                    "value": "'^/win32/ram/load$'",
                    "max": 100,
                    "min": 0,
                    "color": "yellow"
                },
                "value2": {
                    "value": "(round1('^/win32/ram/used$' / 1024))GB",
                    "max": "'^/win32/ram/total$' / 1024",
                    "min": 0,
                    "color": "red",
                    "has_gradient": true
                }
            },
            "bottom": {
                "label": "Disk",
                "color": "salmon",
                "value1": {
                    "value": "max('^/win32/disk/[0-9]+/load$')",
                    "max": 100,
                    "min": 0
                },
                "value2": {
                    "value": "(round1(sum('^/win32/disk/[0-9]+/volume/[0-9]+/used$') / 1024 / 1024))TB",
                    "max": "(round1(sum('^/win32/disk/[0-9]+/volume/[0-9]+/total$') / 1024 / 1024))TB",
                    "min": 0,
                    "color": "goldenrod",
                    "has_gradient": true
                }
            }
        }
    }
]